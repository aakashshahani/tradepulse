{
  "uid": "tradepulse",
  "title": "TradePulse Pipeline",
  "tags": ["tradepulse"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Producer throughput (trades/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (symbol) (rate(tradepulse_trades_total[1m]))",
          "legendFormat": "{{symbol}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Spark processed rows/sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "rps", "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "tradepulse_spark_processed_rows_per_sec",
          "legendFormat": "{{query}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Spark micro-batch duration (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "tradepulse_spark_batch_duration_ms",
          "legendFormat": "{{query}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "trades.raw ingestion (msgs/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_topic_partition_current_offset{topic=\"trades.raw\"}[1m]))",
          "legendFormat": "trades.raw"
        }
      ]
    }
  ]
}
