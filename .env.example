# Copy to .env and adjust as needed. .env is gitignored.

# --- Postgres ---
POSTGRES_USER=tradepulse
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tradepulse

# --- Kafka ---
# Host-side bootstrap address (external HOST listener). Containers on the
# compose network use kafka:9092 instead (set directly on the producer service).
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# --- Producer (Phase 2) ---
# Kafka topic that raw trades are published to.
KAFKA_TOPIC=trades.raw
# Coinbase public Exchange WebSocket feed (no auth required).
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
# Comma-separated Coinbase product IDs to subscribe to.
PRODUCT_IDS=BTC-USD,ETH-USD,SOL-USD
# Producer log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# --- Spark job (Phase 3) ---
# The Spark job reads KAFKA_TOPIC above and writes candles into Postgres. It
# connects in-network (postgres:5432, kafka:9092) using the POSTGRES_* values
# above; no extra required vars. Optional overrides:
# WINDOW_DURATION=1 minute
# WATERMARK_DELAY=1 minute
